use std::ops::OfNat

pub def Nat : prop := enum
    | Zero
    | Succ of (pred : Nat)

pub def zero : Nat := Zero
pub def one : Nat := Succ Zero
pub def two : Nat := Succ (Succ Zero)

#[terminating]
pub def from_int (n : int) : Nat :=
    if n <= 0 then Zero else Succ (from_int (n - 1))

#[instance]
def of_nat_nat : OfNat Nat := OfNat.mk from_int

